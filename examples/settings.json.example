{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/pre-flight.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/session-tip.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/context-reinject.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file_path=$(echo \"$TOOL_INPUT\" | python3 -c \"import sys,json; print(json.load(sys.stdin).get('file_path',''))\" 2>/dev/null); if echo \"$file_path\" | grep -qE '\\.(env|pem|key|credentials)'; then echo 'BLOCKED: Attempting to write to sensitive file: '$file_path >&2; exit 2; fi; exit 0"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd=$(echo \"$TOOL_INPUT\" | python3 -c \"import sys,json; print(json.load(sys.stdin).get('command',''))\" 2>/dev/null); if echo \"$cmd\" | grep -qE 'rm\\s+(-[a-zA-Z]*r[a-zA-Z]*f|-rf|-fr|--recursive.*--force)'; then echo 'BLOCKED: rm -rf is disabled. Use trash instead.' >&2; exit 2; fi; exit 0"
          },
          {
            "type": "command",
            "command": "cmd=$(echo \"$TOOL_INPUT\" | python3 -c \"import sys,json; print(json.load(sys.stdin).get('command',''))\" 2>/dev/null); if echo \"$cmd\" | grep -qE 'git\\s+push\\s+.*\\b(main|master)\\b'; then echo 'BLOCKED: Direct push to main/master. Use a feature branch and PR.' >&2; exit 2; fi; exit 0"
          },
          {
            "type": "command",
            "command": "cmd=$(echo \"$TOOL_INPUT\" | python3 -c \"import sys,json; print(json.load(sys.stdin).get('command',''))\" 2>/dev/null); if echo \"$cmd\" | grep -qE '(curl|wget)\\s+.*\\|\\s*(bash|sh|zsh|dash|csh)'; then echo 'BLOCKED: Pipe-to-shell detected. Download first, review, then run.' >&2; exit 2; fi; exit 0"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/validate-plan.sh"
          }
        ]
      },
      {
        "matcher": "WebSearch|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/gemini-fallback.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Code session complete\" with title \"Claude Code\" sound name \"Glass\"' 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/context-reinject.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/auto-test.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/chronicle-nudge.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "WebSearch",
      "WebFetch",

      "Bash(cd *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(stat *)",
      "Bash(file *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(cat *)",
      "Bash(diff *)",
      "Bash(sort *)",
      "Bash(du *)",
      "Bash(tree *)",
      "Bash(readlink *)",

      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git remote*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git rev-parse*)",
      "Bash(git ls-files*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git clone *)",
      "Bash(git blame *)",

      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(cargo *)",

      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(node *)",
      "Bash(claude *)",

      "Bash(pytest *)",
      "Bash(python -m *)",
      "Bash(python3 -m *)",

      "Bash(eslint *)",
      "Bash(prettier *)",
      "Bash(black *)",
      "Bash(ruff *)",
      "Bash(make *)",

      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(chmod *)",

      "Bash(which *)",
      "Bash(env)",
      "Bash(uname *)",
      "Bash(whoami)",
      "Bash(pwd)",

      "Bash(gh *)",

      "Bash(echo *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(jq *)",
      "Bash(xargs *)",
      "Bash(tr *)",
      "Bash(cut *)",
      "Bash(* --version)",
      "Bash(* --help)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(git push --force*)",
      "Bash(git push * --force*)",
      "Bash(curl * | bash*)",
      "Bash(curl * | sh*)",
      "Bash(wget * | bash*)",
      "Bash(wget * | sh*)",
      "Bash(sudo *)",
      "Bash(eval *)",

      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Edit(~/.zshrc)",
      "Edit(~/.bashrc)"
    ]
  }
}
